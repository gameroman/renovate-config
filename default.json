{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "assignees": ["gameroman"],
  "packageRules": [
    {
      "matchPackageNames": [
        "oxlint",
        "oxfmt",
        "oxlint-tsgolint",
        "@biomejs/biome",
        "@gameroman/config"
      ],
      "groupName": "lint and format tools"
    },
    { "matchPackageNames": ["typescript"], "groupName": "typescript" }
  ]
}
