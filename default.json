{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "assignees": ["gameroman"],
  "reviewers": ["gameroman"],
  "assignAutomerge": true,
  "minimumReleaseAge": "32 hours",
  "internalChecksFilter": "strict",
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "commitMessageAction": "update",
  "packageRules": [
    { "matchPackagePatterns": ["*"], "semanticCommitType": "chore" },
    {
      "matchPackageNames": [
        "oxlint",
        "oxfmt",
        "oxlint-tsgolint",
        "@biomejs/biome",
        "@gameroman/config"
      ],
      "groupName": "lint and format tools"
    },
    { "matchPackageNames": ["typescript"], "groupName": "typescript" },
    {
      "matchPackageNames": ["wrangler", "@cloudflare/vite-plugin"],
      "groupName": "wrangler"
    },
    {
      "matchPackageNames": [
        "astro",
        "@astrojs/cloudflare",
        "@astrojs/react",
        "@astrojs/starlight",
        "@astrojs/solid-js"
      ],
      "groupName": "astro"
    },
    { "matchPackageNames": ["solid-js"], "groupName": "solid-js" },
    {
      "matchPackageNames": ["tsdown", "rolldown-plugin-dts"],
      "groupName": "tsdown"
    },
    { "matchPackageNames": ["grammy"], "groupName": "grammy" },
    { "matchPackageNames": ["esbuild"], "groupName": "esbuild" },
    {
      "matchPackageNames": [
        "tailwindcss",
        "@tailwindcss/vite",
        "@tailwindcss/typography"
      ],
      "groupName": "tailwindcss"
    }
  ]
}
