{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "assignees": ["gameroman"],
  "reviewers": ["gameroman"],
  "assignAutomerge": true,
  "minimumReleaseAge": "1 day",
  "internalChecksFilter": "strict",
  "packageRules": [
    {
      "matchPackageNames": [
        "oxlint",
        "oxfmt",
        "oxlint-tsgolint",
        "@biomejs/biome",
        "@gameroman/config"
      ],
      "groupName": "lint and format tools"
    },
    { "matchPackageNames": ["typescript"], "groupName": "typescript" },
    {
      "matchPackageNames": ["esbuild"],
      "groupName": "esbuild",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "platformAutomerge": true
    }
  ]
}
