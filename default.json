{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "assignees": ["gameroman"],
  "reviewers": ["gameroman"],
  "assignAutomerge": true,
  "minimumReleaseAge": "32 hours",
  "internalChecksFilter": "strict",
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "commitMessageAction": "update",
  "packageRules": [
    {
      "matchPackageNames": [
        "oxlint",
        "oxfmt",
        "oxlint-tsgolint",
        "@biomejs/biome",
        "@gameroman/config"
      ],
      "groupName": "lint and format tools"
    },
    { "matchPackageNames": ["typescript"], "groupName": "typescript" },
    { "matchPackageNames": ["wrangler"], "groupName": "wrangler" },
    {
      "matchPackageNames": ["astro", "@astrojs/cloudflare"],
      "groupName": "astro"
    },
    { "matchPackageNames": ["solid-js"], "groupName": "solid-js" },
    { "matchPackageNames": ["tsdown"], "groupName": "tsdown" },
    { "matchPackageNames": ["grammy"], "groupName": "grammy" },
    {
      "matchPackageNames": ["esbuild"],
      "groupName": "esbuild",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "platformAutomerge": true
    }
  ]
}
